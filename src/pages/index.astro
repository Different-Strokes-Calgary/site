---
import '../styles/global.css';
import { club, isConfigured } from '../data/club';

const joinReady = isConfigured(club.joinUrl);
const contactHref = isConfigured(club.contactUrl)
  ? club.contactUrl
  : 'mailto:info@differentstrokescalgary.org';
const calendarReady = isConfigured(club.calendarEmbedUrl);
const calendarOpenHref = isConfigured(club.calendarOpenUrl)
  ? club.calendarOpenUrl
  : club.calendarEmbedUrl;
const merchHref = isConfigured(club.merchStoreUrl)
  ? club.merchStoreUrl
  : 'https://differentstrokescalgary.org/merch';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content="Different Strokes Calgary is an LGBTQ+ masters swim club for fun and fitness for life." />
    <title>Different Strokes Calgary | Fun and fitness for life</title>
    <!-- OpenGraph / Social Media Link Preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Different Strokes Calgary | Fun and fitness for life" />
    <meta property="og:description" content="Different Strokes Calgary is an LGBTQ+ masters swim club for fun and fitness for life." />
    <meta property="og:image" content="/site/assets/hero-art-dark.png" />
    <meta property="og:image:alt" content="Different Strokes Calgary swimmers moving through water under a sweeping rainbow on dark background." />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Different Strokes Calgary | Fun and fitness for life" />
    <meta name="twitter:description" content="Different Strokes Calgary is an LGBTQ+ masters swim club for fun and fitness for life." />
    <meta name="twitter:image" content="/site/assets/hero-art-dark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('dsc-theme');
          document.documentElement.dataset.theme = saved ?? 'dark';
        } catch {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" data-header>
      <button class="menu-toggle" type="button" aria-controls="site-nav" aria-expanded="false">
        <span class="sr-only">Open navigation</span>
        <span aria-hidden="true"></span><span aria-hidden="true"></span>
      </button>
      <nav id="site-nav" aria-label="Main navigation">
        <a href="#practice">Practice &amp; Schedule</a>
        <a href="#join">Join Us</a>
        <a href="#story">Our Story</a>
        <a class="nav-contact" href={contactHref}>Contact Us</a>
        <a class="nav-merch" href={merchHref} target="_blank" rel="noreferrer">Merch Store ↗</a>
      </nav>
      <a class="brand" href="#top" aria-label="Different Strokes Calgary home">
        <img src="/site/assets/dsc-logo.svg" alt="Different Strokes Calgary LGBT+ Masters Swim Club" width="137" height="68" />
      </a>
      <div class="header-actions">
        <a class="button button--outline header-merch" href={merchHref} target="_blank" rel="noreferrer">Merch Store</a>
        <a class="button header-contact" href={contactHref}>Contact Us</a>
        <button class="theme-toggle" type="button" aria-label="Switch to dark theme" aria-pressed="false">
          <span class="theme-toggle__sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" focusable="false" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m6.34 17.66-1.41 1.41" />
              <path d="m19.07 4.93-1.41 1.41" />
            </svg>
          </span>
          <span class="theme-toggle__moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" focusable="false" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
            </svg>
          </span>
          <span class="sr-only">Switch theme</span>
        </button>
      </div>
    </header>

    <main id="main">
      <section class="hero" id="top" aria-labelledby="hero-title">
        <div class="hero__copy reveal">
          <p class="hero__mark">Calgary’s LGBTQ+ masters swim club</p>
          <h1 id="hero-title">Fun and fitness<span class="hero__desktop-break"><br /></span> for life.</h1>
          <p>Swim for fitness, friendship, and the joy of feeling at home in the water. All ages, abilities, LGBTQ+ swimmers, and allies welcome.</p>
          <a class="text-link" href="#story">Learn more <span aria-hidden="true">→</span></a>
        </div>
        <div class="hero__art">
          <img class="hero__illustration hero__illustration--light" src="/site/assets/hero-art-light.png" alt="Four diverse swimmers moving through water and a sweeping rainbow." width="1774" height="887" />
          <img class="hero__illustration hero__illustration--dark" src="/site/assets/hero-art-dark.png" alt="" aria-hidden="true" width="1774" height="887" />
        </div>
      </section>

      <section class="practice" id="practice" aria-labelledby="practice-title">
        <div class="section-heading practice__heading reveal">
          <p class="section-kicker">Summer schedule · Jul–Aug 2026</p>
          <h2 id="practice-title">Practice at<br />a glance.</h2>
          <p class="section-intro">Coached workouts for recreational and competitive swimmers. Work at your own pace, in the lane that suits you.</p>
        </div>
        <div class="practice-schedule-group">
          <ol class="practice-list" aria-label="Summer practice times">
            {club.practices.map((practice, index) => (
              <li class="reveal" style={`--i: ${index}`}>
                <strong>{practice.day}</strong>
                <span>{practice.time}</span>
                <span>{practice.place}</span>
                <em>{practice.level}</em>
              </li>
            ))}
          </ol>
        </div>

        <div class="practice__details">
          <details class="calendar-details disclosure-card">
            <summary class="disclosure-bar">
              <span>View live practice calendar</span>
              <span class="chevron" aria-hidden="true">▾</span>
            </summary>
            {calendarReady ? (
              <div class="calendar-frame">
                <div class="calendar-header">
                  <div class="calendar-status">
                    <span class="calendar-status__dot"></span>
                    <span>Live practice schedule</span>
                  </div>
                  <a class="text-link calendar-open-link" href={calendarOpenHref} target="_blank" rel="noreferrer">Open in Google Calendar <span aria-hidden="true">↗</span></a>
                </div>
                <iframe title="Different Strokes Calgary practice calendar" src={club.calendarEmbedUrl} loading="lazy"></iframe>
              </div>
            ) : (
              <p class="calendar-pending">The public calendar link will appear here. Until then, email <a href="mailto:info@differentstrokescalgary.org">info@differentstrokescalgary.org</a> for the latest schedule.</p>
            )}
          </details>

          <details class="disclosure-card">
            <summary class="disclosure-bar">
              <span>Locations &amp; parking</span>
              <span class="chevron" aria-hidden="true">▾</span>
            </summary>
            <div class="details-grid">
              <div>
                <h3>Locations &amp; parking</h3>
                <p>MNP Community &amp; Sports Centre · 2225 Macleod Trail S<br />Killarney Aquatic &amp; Recreation Centre · 1919 29 St SW<br />Bowview Outdoor Pool · 1910 6 Ave NW</p>
                <p>At MNP, parking is free for up to three hours from 4:00 AM–4:00 PM on weekdays, two hours from 4:00 PM–4:00 AM on weekdays, and two hours on weekends. Cameras start and end sessions automatically; longer stays can be paid by app or kiosk. Free auxiliary parking is available at Indigo Lot #286 near Elbow River Casino when the main lot fills during events.</p>
              </div>
              <div>
                <h3>Come prepared</h3>
                <p>Bring a swimsuit, towel, goggles, and preferably a cap and lock. Keep valuables at home or on deck with you.</p>
                <p>We welcome swimmers who know the basics. Coaches help with technique and fitness; beginner swimmers are not expected to arrive already polished, but DSC does not teach people to swim from scratch.</p>
              </div>
            </div>
          </details>

          <details class="disclosure-card">
            <summary class="disclosure-bar">
              <span>Workout guide &amp; pool etiquette</span>
              <span class="chevron" aria-hidden="true">▾</span>
            </summary>
            <div class="details-grid guide-grid">
              <div>
                <h3>Every kind of swimmer</h3>
                <p>DSC supports recreational and competitive swimming. Coaching develops technique and fitness, while every swimmer is encouraged to work at their own pace and comfort level.</p>
                <p>Competitive swimmers follow structured, progressive, goal-oriented workouts. Everyone is welcome at masters meets; there are no minimum requirements.</p>
                <p>Workouts develop freestyle, backstroke, breaststroke, and butterfly.</p>
              </div>
              <div>
                <h3>On deck</h3>
                <p>Choose a lane that suits your level: lane 1 is for beginners, lane 6 for advanced swimmers, and lanes 2–5 sit between those levels.</p>
                <p>After practice, swimmers cool down in the hot tub for announcements. Club members often go for dinner afterward; everyone is welcome.</p>
              </div>
              <div>
                <h3>Share the lane well</h3>
                <ul class="guide-list">
                  <li>Help set up and put away lane ropes and training equipment.</li>
                  <li>If late, join at the point your lane has reached.</li>
                  <li>Circle swim, stay off the centre line, and follow your lane’s direction.</li>
                  <li>Set order from fastest to slowest; the lead swimmer keeps the lane on pace.</li>
                  <li>Leave five to ten seconds between swimmers during repeats.</li>
                  <li>Touch toes once to request a pass; let the faster swimmer through at the wall.</li>
                  <li>Ease toward the wall before turning so you can push off straight.</li>
                  <li>Follow the posted workout, or move lanes if you are doing something different.</li>
                  <li>Rest at the side of the lane so others can turn safely.</li>
                  <li>Smile—then help tidy up when the workout ends.</li>
                </ul>
              </div>
            </div>
          </details>
        </div>
      </section>

      <section class="join" id="join" aria-labelledby="join-title">
        <div class="section-heading join__heading reveal">
          <div class="join__header-row">
            <div>
              <p class="section-kicker">Membership</p>
              <h2 id="join-title">Find your way in.</h2>
            </div>
            <a class="button join__button" href={club.joinUrl}>Join Us</a>
          </div>
          <p class="section-intro">There is currently a waitlist for new non-returning members. Click Join Us to sign up for the waitlist. Returning members can click Join Us to renew membership.</p>
        </div>
        <div class="fee-table reveal">
          <div class="fee-table__header">
            <span>Membership Tier</span>
            <span>Price</span>
            <span>Coverage &amp; Details</span>
          </div>
          {club.fees.map((fee) => (
            <div class="fee-row">
              <strong class="fee-row__name">{fee.name}</strong>
              <span class="fee-row__price">{fee.price}</span>
              <span class="fee-row__detail">{fee.detail}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="story" id="story" aria-labelledby="story-title">
        <div class="story-grid reveal">
          <div class="story__mission">
            <p class="section-kicker">Our community, our story</p>
            <h2 id="story-title">A place to swim<br />as yourself.</h2>
            <p>Different Strokes Calgary began with its first workout in 1995. Today, we are a volunteer-run club making room for fitness, friendship, and the full range of swimmers in our community.</p>
            <p>We support the inclusion of trans athletes in recreational and competitive swimming, without qualification.</p>
          </div>

          <div class="story__coaches">
            <h3 class="coaches-title">Meet the Coaches</h3>
            <div class="coach-cards">
              <article class="coach-card">
                <strong>Dan MacGregor</strong>
                <span>Co-Founder &amp; Beginner Coach</span>
                <p>Co-founded DSC in 1995. Swim Canada Volunteer of the Year 2024.</p>
              </article>
              <article class="coach-card">
                <strong>Tammy Andersen</strong>
                <span>Head Coach</span>
                <p>25+ years coaching experience. Killarney Swim Club Lead &amp; MNP 3433 coach.</p>
              </article>
            </div>
          </div>

          <details class="disclosure-card story__archive">
            <summary class="disclosure-bar">
              <span>Full Coach Bios, Club History &amp; Competition Highlights</span>
              <span class="chevron" aria-hidden="true">▾</span>
            </summary>
            <div class="story-archive__content">
              <section class="archive-group">
                <h3>Dan MacGregor · Co-Founder &amp; Beginner Coach</h3>
                <p>Dan co-founded DSC and has coached beginner swimmers since the club began. An accountant by trade, he may vanish during tax season, but the club makes sure swimmers are looked after. His continued volunteer work earned Swim Canada’s Volunteer of the Year award in 2024.</p>

                <h3>Tammy Andersen · Head Coach</h3>
                <p>Tammy joined DSC in November 2022 and full time in spring 2025. With more than 25 years of coaching, she has led the Glenmore Seals and Okotoks Stingrays summer clubs, assisted the Calgary Tritons, and helped the City of Calgary develop youth and adult conditioning programs.</p>
                <p>She coached junior national swimmers in Limburg, Belgium while studying education. Tammy is now Sprocket Coordinator and Junior 1 Lead Coach at Killarney Swim Club, leads the swim program at 3433 Sport Performance at MNP, and is a Swim Canada-certified coach working toward full 201 certification. Her coaching focuses on swimming science, individual feedback, form, and celebrating every swimmer’s progress.</p>
              </section>

              <section class="archive-group">
                <h3>Mission</h3>
                <p>Different Strokes Calgary is a non-profit, volunteer club for LGBTQ+ members. DSC follows a “fun and fitness for life” philosophy in a positive, supportive space where members can choose recreational, competitive, and social participation.</p>

                <h3>Club History</h3>
                <p>Calgary’s first swim club for lesbian, gay, and bisexual communities began in early 1993 as Chinook City Aquatics, organized by David Whiteside. It ended after six months because interest was too low.</p>
                <p>Dan MacGregor and James Cooke revived the idea as Different Strokes Calgary. After gathering swimmers to test interest, the group agreed to a three-month trial of weekly swims. The first DSC workout was held March 5, 1995 at Lindsay Park Sports Centre, with Dan as head coach, Nancy Ingram coaching beginners, Rick Matthews coaching competitive swimmers, and thirteen swimmers on deck.</p>
                <p>That September, DSC moved to the YWCA and added Wednesday and Sunday practices. Rita Bercan later became head coach with Graham Taylor as assistant; after Rita left, Graham became head coach while Dan and Pat Lee Loy continued beginner coaching. Pat later moved to Pennsylvania and joined the Philadelphia Fins. By 1997, DSC averaged about 20 swimmers per practice and had more than 40 members.</p>
                <p>In 2007, Sunday practice moved to SAIT while Wednesday remained at the YWCA; later that year both sessions moved to SAIT on Thursdays and Sundays. In 2015, DSC added Wednesday nights at Talisman Centre. From fall 2016, Friday and Sunday practices moved to Repsol Sports Centre, now MNP Community &amp; Sports Centre.</p>

                <h3>Competition, Social Life &amp; Inclusion</h3>
                <p>DSC belongs to Swim Alberta, FINA, and International Gay and Lesbian Aquatics. Members have competed across North America, including Washington DC, Seattle, San Francisco, Atlanta, Edmonton, Calgary, and Vancouver, and in Paris, Reykjavik, Amsterdam, and Copenhagen. The club has also participated in Gay Games and Outgames events in Sydney, Chicago, Montréal, and Copenhagen.</p>
                <p>Alongside swimming, DSC is known for social events and community fundraising, including a breast-cancer swim-a-thon, Small Change Big Changes, and Calgary Cares. DSC supports inclusive sport where people can build confidence, community, and lifelong swimming skills regardless of gender identity, and unequivocally supports trans athletes in recreational and competitive swimming.</p>
              </section>
            </div>
          </details>
        </div>
      </section>

      <section class="story-art" aria-label="Different Strokes Calgary community illustration">
        <figure class="story-art__figure reveal">
          <img class="story-art__illustration story-art__illustration--light" src="/site/assets/story-community-light.png" alt="A diverse group of swimmers smiling together in a pool beneath rainbow bunting." width="1774" height="887" />
          <img class="story-art__illustration story-art__illustration--dark" src="/site/assets/story-community-dark.png" alt="" aria-hidden="true" width="1774" height="887" />
          <figcaption class="sr-only">Different Strokes Calgary community.</figcaption>
        </figure>
      </section>
    </main>

    <footer>
      <a class="brand brand--footer" href="#top"><img src="/site/assets/dsc-logo.svg" alt="Different Strokes Calgary LGBT+ Masters Swim Club" width="137" height="68" /></a>
      <p>Fun and fitness for life.</p>
      <div class="footer-links">
        <div class="footer-board">
          <a href="https://clubbots.wlabscode.com/admin/signin" target="_blank" rel="external noopener noreferrer" data-external-browser>Board sign in <span aria-hidden="true">↗</span></a>
          <span class="footer-powered"><strong>Powered by</strong> <a href="https://clubbots.wlabscode.com/" target="_blank" rel="external noopener noreferrer" data-external-browser><strong>club & bots</strong></a></span>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
      const nav = document.querySelector<HTMLElement>('#site-nav');
      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav?.toggleAttribute('data-open', !open);
      });

      nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        toggle?.setAttribute('aria-expanded', 'false');
        nav.removeAttribute('data-open');
      }));

      const themeToggle = document.querySelector<HTMLButtonElement>('.theme-toggle');
      const themeLabel = themeToggle?.querySelector<HTMLElement>('.sr-only');
      const updateThemeToggle = (theme: string) => {
        const nextTheme = theme === 'dark' ? 'light' : 'dark';
        themeToggle?.setAttribute('aria-pressed', String(theme === 'dark'));
        themeToggle?.setAttribute('aria-label', `Switch to ${nextTheme} theme`);
        if (themeLabel) themeLabel.textContent = `Switch to ${nextTheme} theme`;
      };
      updateThemeToggle(document.documentElement.dataset.theme ?? 'dark');
      themeToggle?.addEventListener('click', () => {
        const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = theme;
        localStorage.setItem('dsc-theme', theme);
        updateThemeToggle(theme);
      });

      const isStandalone = window.matchMedia('(display-mode: standalone)').matches
        || (window.navigator as Navigator & { standalone?: boolean }).standalone === true;
      if (isStandalone) {
        document.querySelectorAll<HTMLAnchorElement>('a[data-external-browser]').forEach((link) => {
          link.addEventListener('click', (event) => {
            event.preventDefault();
            window.open(link.href, '_blank', 'noopener,noreferrer');
          });
        });
      }

      const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!prefersReducedMotion) {
        document.querySelectorAll<HTMLElement>('.button, .theme-toggle, .menu-toggle').forEach((control) => {
          control.addEventListener('pointerdown', (event) => {
            const rect = control.getBoundingClientRect();
            const ripple = document.createElement('span');
            ripple.className = 'button__ripple';
            ripple.style.left = `${event.clientX - rect.left}px`;
            ripple.style.top = `${event.clientY - rect.top}px`;
            control.append(ripple);
            ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
          });
        });
      }

      const navLinks = [...document.querySelectorAll<HTMLAnchorElement>('#site-nav a[href^="#"]')];
      const sections = navLinks
        .map((link) => document.querySelector(link.hash))
        .filter((section): section is HTMLElement => Boolean(section));
      const observer = new IntersectionObserver((entries) => {
        const current = entries.find((entry) => entry.isIntersecting);
        if (!current) return;
        navLinks.forEach((link) => link.toggleAttribute('aria-current', link.hash === `#${current.target.id}`));
      }, { rootMargin: '-35% 0px -55% 0px', threshold: 0 });
      sections.forEach((section) => observer.observe(section));
    </script>
  </body>
</html>
